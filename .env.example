# Application
APP_NAME=PulseGuard-AI
APP_VERSION=1.0.0
DEBUG=true

# Database (SQLAlchemy Asyncpg format for Docker Compose)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/rag_of_fire

# Redis
REDIS_URL=redis://localhost:6379/0

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Security
JWT_SECRET=super_secret_jwt_key_change_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Vector DB
VECTOR_DB_PATH=./data/chroma_db
EMBEDDING_MODEL=text-embedding-3-small

# LLM Integration
USE_REAL_LLM=true
LLM_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=
LLM_MODEL=gpt-4-turbo

# Notifications
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SLACK_WEBHOOK_URL=

# Server
HOST=0.0.0.0
PORT=8000