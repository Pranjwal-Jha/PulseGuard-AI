# Application
APP_NAME=RAG of Fire
APP_VERSION=1.0.0
DEBUG=true

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rag_of_fire

# Vector DB
VECTOR_DB_PATH=./data/chroma_db
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# LLM
USE_REAL_LLM=false
LLM_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_MODEL=gpt-4-turbo

# Notifications
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SLACK_WEBHOOK_URL=
# Server
HOST=0.0.0.0
PORT=8000